# Database
DATABASE_URL="postgresql://hookscope:hookscope@localhost:5432/hookscope"
REDIS_URL="redis://localhost:6379"

# Blockchain RPC (get free keys at alchemy.com / infura.io)
ETHEREUM_RPC_URL="https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY"
BASE_RPC_URL="https://base-mainnet.g.alchemy.com/v2/YOUR_KEY"
ARBITRUM_RPC_URL="https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY"
OPTIMISM_RPC_URL="https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY"

# Etherscan API keys (get at etherscan.io)
ETHERSCAN_API_KEY="YOUR_ETHERSCAN_KEY"
BASESCAN_API_KEY="YOUR_BASESCAN_KEY"
ARBISCAN_API_KEY="YOUR_ARBISCAN_KEY"
OPTIMISTIC_ETHERSCAN_API_KEY="YOUR_OPTIMISM_KEY"

# API Configuration
API_PORT=3001
API_SECRET="change-me-in-production"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Notifications (optional)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# Environment
NODE_ENV="development"
