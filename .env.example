# ── Database ──────────────────────────────────────────────────────────────────
# Local Docker: postgresql://hookscope:hookscope@localhost:5432/hookscope
# Railway: provided automatically when you add a PostgreSQL service
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/hookscope"
REDIS_URL="redis://localhost:6379"

# ── Blockchain RPC ────────────────────────────────────────────────────────────
# Get free keys at https://dashboard.alchemy.com/ (300M CU/month)
ETHEREUM_RPC_URL="https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY"
ARBITRUM_RPC_URL="https://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY"
BASE_RPC_URL="https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY"
OPTIMISM_RPC_URL="https://opt-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY"

# ── The Graph ─────────────────────────────────────────────────────────────────
# Get free API key at https://thegraph.com/studio
# Required for real-time ETH/USDC prices on Ethereum + Arbitrum
GRAPH_API_KEY=""

# ── Etherscan ─────────────────────────────────────────────────────────────────
# For verified source code and ABI fetching — https://etherscan.io/myapikey
ETHERSCAN_API_KEY=""

# ── API Server ────────────────────────────────────────────────────────────────
API_PORT=3001
# In production: set to your Vercel frontend URL (e.g. https://hookscope.vercel.app)
CORS_ORIGIN="http://localhost:3000"

# ── Frontend ──────────────────────────────────────────────────────────────────
# In production: set to your Railway API URL (e.g. https://hookscope-api.up.railway.app)
NEXT_PUBLIC_API_URL="http://localhost:3001"

NODE_ENV="development"

# ── Anvil (local dev / testing) ──────────────────────────────────────────────
# Start a mainnet fork:  pnpm anvil:start
# Deploy test tokens:    pnpm anvil:setup   (first time only)
# Verify transactions:   pnpm anvil:test
#
# All Uniswap v4 contracts (PoolManager, StateView, PositionManager, Quoter)
# are automatically available at the same mainnet addresses on the fork.
# Set ETHEREUM_RPC_URL to a real mainnet RPC (Alchemy/Infura) for forking.
ANVIL_RPC_URL="http://127.0.0.1:8545"
# This is Anvil's first well-known test key — NEVER use on mainnet.
ANVIL_PRIVATE_KEY="0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80"
